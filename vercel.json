{
  "framework": "vite",
  "name": "q-trade",
  "functions": {
    "api/*.py": {
      "runtime": "vercel-python@1.3.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
       "source": "/(.*)",
       "destination": "/index.html"
    }
  ]
}

