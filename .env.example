# ─────────────────────────────────────────────────────────────────
# Q-Trade .env.example
# Copy this file to .env and fill in real values before deploying.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# SQLite (default, fine for VPS single-instance)
DATABASE_URL=sqlite:///./data/qtrade.db

# ── Auth ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Environment ────────────────────────────────────────────────────
# Set to "production" to hide /docs and enable prod hardening
ENVIRONMENT=production

# ── Admin Seed ─────────────────────────────────────────────────────
# Used by scripts/seed_admin.py on first deploy
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_NAME=Platform Admin
